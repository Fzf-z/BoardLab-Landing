---
import type { Lang } from '../i18n/utils';
import { t } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tr = t(lang);
---

<section id="demo" class="bg-slate-50 py-20 sm:py-24">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 text-center">
    <span class="text-sm font-semibold uppercase tracking-wider text-blue-600">{tr.demo.label}</span>
    <h2 class="mt-3 text-3xl font-bold text-slate-900 sm:text-4xl">{tr.demo.title}</h2>

    <div class="mt-10 aspect-video overflow-hidden rounded-xl border border-slate-200 shadow-lg">
      <iframe
        src="https://www.youtube.com/embed/ZaE3xGL6VEM"
        title="BoardLab Pro Demo"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        class="h-full w-full"
        loading="lazy"
      ></iframe>
    </div>
  </div>
</section>
