---
import type { Lang } from '../i18n/utils';
import { t } from '../i18n/utils';
import { DOWNLOAD_URL } from '../config';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tr = t(lang);
const downloadUrl = DOWNLOAD_URL;

// Split the title to wrap the highlighted word with a gradient span
const highlightWord = tr.hero.titleHighlight;
const titleParts = tr.hero.title.split(highlightWord);
---

<section class="hero-section relative overflow-hidden bg-slate-900">
  <!-- Background: subtle grid pattern overlay -->
  <div class="absolute inset-0 bg-grid-pattern opacity-[0.03]" aria-hidden="true"></div>

  <!-- Background: radial gradient glow -->
  <div class="absolute inset-0" aria-hidden="true">
    <div class="absolute left-1/2 top-1/3 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[600px] rounded-full bg-blue-600/[0.07] blur-[120px]"></div>
    <div class="absolute left-1/2 top-1/2 -translate-x-1/3 -translate-y-1/3 w-[600px] h-[400px] rounded-full bg-teal-600/[0.05] blur-[100px]"></div>
  </div>

  <!-- Hero content -->
  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-32 sm:pt-36 lg:pt-40 pb-0 text-center">
    <!-- Badge -->
    <div class="hero-fade-in" style="animation-delay: 0.3s;">
      <span class="inline-block rounded-full border border-blue-500/30 bg-blue-500/10 px-4 py-1.5 text-sm text-blue-400">
        {tr.hero.badge}
      </span>
    </div>

    <!-- Headline -->
    <h1 class="hero-fade-in mx-auto mt-8 max-w-4xl text-5xl font-bold leading-tight text-white md:text-6xl lg:text-7xl" style="animation-delay: 0.4s;">
      {titleParts[0]}<span class="bg-gradient-to-r from-blue-400 to-teal-400 bg-clip-text text-transparent">{highlightWord}</span>{titleParts[1]}
    </h1>

    <!-- Subtitle -->
    <p class="hero-fade-in mx-auto mt-6 max-w-2xl text-lg text-slate-400 md:text-xl" style="animation-delay: 0.5s;">
      {tr.hero.subtitle}
    </p>

    <!-- CTAs -->
    <div class="hero-fade-in mt-8 flex flex-wrap items-center justify-center gap-4" style="animation-delay: 0.6s;">
      <a
        href={downloadUrl}
        class="inline-flex items-center rounded-xl bg-gradient-to-r from-blue-600 to-teal-600 px-8 py-3.5 text-lg font-semibold text-white transition-all hover:shadow-lg hover:shadow-blue-500/25 hover:scale-[1.03] hover:brightness-110 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 focus-visible:ring-offset-slate-900"
      >
        {tr.hero.ctaPrimary}
      </a>
      <a
        href="#pricing"
        class="inline-flex items-center rounded-xl border border-slate-600 px-8 py-3.5 text-lg font-semibold text-slate-300 transition-all hover:border-slate-400 hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 focus-visible:ring-offset-slate-900"
      >
        {tr.hero.ctaSecondary}
      </a>
    </div>

    <!-- Hero image: app window mockup with screenshot tabs -->
    <div class="hero-fade-in-image mt-16 sm:mt-20 mx-auto max-w-5xl" style="animation-delay: 0.8s;">
      <div class="hero-window rounded-xl border border-slate-700/50 bg-slate-800/50 shadow-2xl shadow-black/50 backdrop-blur">
        <!-- Window title bar with screenshot tabs -->
        <div class="flex items-center gap-2 px-4 py-2.5">
          <span class="h-3 w-3 rounded-full bg-red-500/60" aria-hidden="true"></span>
          <span class="h-3 w-3 rounded-full bg-yellow-500/60" aria-hidden="true"></span>
          <span class="h-3 w-3 rounded-full bg-green-500/60" aria-hidden="true"></span>
          <div class="ml-4 flex gap-1">
            <button
              type="button"
              class="hero-tab active rounded-md px-3 py-1 text-xs font-medium text-slate-400 transition-colors hover:text-white"
              data-tab="0"
            >
              {tr.hero.tab1}
            </button>
            <button
              type="button"
              class="hero-tab rounded-md px-3 py-1 text-xs font-medium text-slate-400 transition-colors hover:text-white"
              data-tab="1"
            >
              {tr.hero.tab2}
            </button>
          </div>
        </div>
        <!-- Screenshots -->
        <div class="relative overflow-hidden">
          <img
            src="/screenshots/image1.png"
            alt="BoardLab Pro — PCB diagnostics with dual board view and measurement points table"
            class="hero-screenshot w-full rounded-b-lg transition-opacity duration-500"
            data-index="0"
            loading="eager"
            decoding="async"
          />
          <img
            src="/screenshots/image2.png"
            alt="BoardLab Pro — Boardview overlay with component mapping and diagnostics"
            class="hero-screenshot w-full rounded-b-lg absolute inset-0 opacity-0 transition-opacity duration-500"
            data-index="1"
            loading="eager"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom gradient fade to light background -->
  <div class="relative z-10 h-24 bg-gradient-to-b from-slate-900 to-slate-50" aria-hidden="true"></div>
</section>

<style>
  /* Grid pattern background */
  .bg-grid-pattern {
    background-image:
      linear-gradient(rgba(148, 163, 184, 0.3) 1px, transparent 1px),
      linear-gradient(90deg, rgba(148, 163, 184, 0.3) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  /* Fade-in-up animation */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeInUpLarge {
    from {
      opacity: 0;
      transform: translateY(40px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-fade-in {
    opacity: 0;
    animation: fadeInUp 0.7s ease-out forwards;
  }

  .hero-fade-in-image {
    opacity: 0;
    animation: fadeInUpLarge 0.9s ease-out forwards;
  }

  /* Screenshot tab styles */
  .hero-tab.active {
    background: rgb(30 41 59 / 0.8);
    color: white;
  }

  /* Desktop: slight perspective tilt on window mockup */
  @media (min-width: 768px) {
    .hero-window {
      transform: perspective(1500px) rotateX(2deg);
    }
  }

  /* Mobile: no tilt */
  @media (max-width: 767px) {
    .hero-window {
      transform: none;
    }
  }
</style>

<script>
  const tabs = document.querySelectorAll('.hero-tab');
  const img0 = document.querySelector('.hero-screenshot[data-index="0"]') as HTMLElement;
  const img1 = document.querySelector('.hero-screenshot[data-index="1"]') as HTMLElement;

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const index = tab.getAttribute('data-tab');
      tabs.forEach((t) => t.classList.remove('active'));
      tab.classList.add('active');

      if (index === '1') {
        img0.style.opacity = '0';
        img1.style.opacity = '1';
      } else {
        img0.style.opacity = '1';
        img1.style.opacity = '0';
      }
    });
  });
</script>

