---
import type { Lang } from '../i18n/utils';
import { t, getLocalizedPath } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tr = t(lang);
---

<footer class="bg-slate-900 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Legal links -->
    <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm">
      <a href={getLocalizedPath(lang, '/changelog')} class="text-slate-400 hover:text-white transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:rounded">
        {tr.footer.changelog}
      </a>
      <a href={getLocalizedPath(lang, '/terms')} class="text-slate-400 hover:text-white transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:rounded">
        {tr.footer.terms}
      </a>
      <a href={getLocalizedPath(lang, '/privacy')} class="text-slate-400 hover:text-white transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:rounded">
        {tr.footer.privacy}
      </a>
      <a href={getLocalizedPath(lang, '/refund')} class="text-slate-400 hover:text-white transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:rounded">
        {tr.footer.refund}
      </a>
      <a href="mailto:support@board-lab.pro" class="text-slate-400 hover:text-white transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:rounded">
        {tr.footer.support}
      </a>
    </div>

    <!-- Copyright -->
    <p class="mt-4 text-center text-sm text-slate-500">{tr.footer.copyright}</p>
  </div>
</footer>
